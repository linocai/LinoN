# LinoN 后端配置示例。复制为 .env 后填值(.env 已进 .gitignore,绝不提交)。
#
#   cp .env.example .env
#
# 缺失任何字段都不会让程序崩溃(优雅降级):
#   · TUSHARE_TOKEN 缺失   → Tushare 四接口返回 ok=False,reason="token 缺失",走静态日历兜底
#   · DEEPSEEK_API_KEY 缺失 → 阶段 2 的 DeepSeek 调用降级(本期不涉及)

# Tushare 2000 积分会员 token(待用户购买后录入;占位可空)
TUSHARE_TOKEN=

# DeepSeek API Key(阶段 2 用;本期留空)
DEEPSEEK_API_KEY=

# SQLite 落盘路径(可留空走默认 backend/data/linon.db)
# DB_PATH=/absolute/path/to/linon.db

# —— 阶段1 API 鉴权(单用户共享密钥;Bearer 比对,len>=16,启动 fail-fast)——
# 本地用 `python -c "import secrets; print(secrets.token_hex(32))"` 生成 64 字符填入 .env。
API_TOKEN=

# —— 阶段1 APNs 直连(token-based JWT;.p8 私钥不入 git,搬 ECS secret mode 600)——
# KeyID/TeamID/BundleID 已齐(见 PROJECT_PLAN §3);.p8 路径指向 ECS secret 落点。
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
APNS_KEY_PATH=
APNS_USE_SANDBOX=true
# 硬线未 ack 的升级重复间隔(分钟)
ESCALATE_INTERVAL_MIN=15

# —— 部署用(sync.sh 读取;留空时 sync.sh 优雅提示退出,不误同步)——
# LINON_DEPLOY_HOST=
# LINON_DEPLOY_USER=
# LINON_DEPLOY_PATH=
